{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/ippuc-arcgis/:path*",
      "destination": "https://geocuritiba.ippuc.org.br/:path*"
    },
    {
      "source": "/overpass-api/:path*",
      "destination": "https://overpass-api.de/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
